# Anthropic API Key（Claude，paper_reader、wallstreet_ai）
# 获取地址：https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Groq API Key（免费，AI 摘要）
# 获取地址：https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# NewsAPI Key（主源，英文财经新闻，免费：100次/天）
# 获取地址：https://newsapi.org/register
NEWSAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GNews Key（financial_news 新闻源，免费：100次/天）
# 获取地址：https://gnews.io/
GNEWS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server酱 SendKey（微信推送）
# 获取步骤：
#   1. 打开 https://sct.ftqq.com/
#   2. 用微信扫码登录
#   3. 点击「SendKey」复制你的密钥（格式：SCTxxxxxxxx）
SERVERCHAN_KEY=SCTxxxxxxxxxxxxxxxxxxxxxxxx
